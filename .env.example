# HubSpot Private App token (server-side only, never sent to the client).
# Without it the app runs in Demo mode with generated sample data.
HUBSPOT_TOKEN=

# Auth.js session-cookie signing secret. Generate with: openssl rand -base64 32
AUTH_SECRET=

# Google OAuth client (Google Cloud Console → APIs & Services → Credentials).
# Sign-in is restricted to verified @plusplus.co Workspace accounts (src/auth.ts).
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
